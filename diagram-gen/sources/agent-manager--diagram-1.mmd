graph TD
    IQ[("Inbound Queue")]
    DEQUEUE["AgentManager.run()<br/>dequeue message"]
    TYPECHECK{"content_type<br/>== 'text'?"}
    DROP["Drop silently"]
    PROCESS["AgentManager._process()"]
    THREADID["thread_id =<br/>channel:sender_id"]
    INVOKE["agent.ainvoke()<br/>with thread_id config"]
    SUCCESS["Extract reply<br/>from result"]
    ERROR["Use fallback<br/>error message"]
    REPLY["Construct reply<br/>UnifiedMessage"]
    OQ[("Outbound Queue")]

    IQ --> DEQUEUE
    DEQUEUE --> TYPECHECK
    TYPECHECK -->|"no"| DROP
    TYPECHECK -->|"yes"| PROCESS
    PROCESS --> THREADID
    THREADID --> INVOKE
    INVOKE -->|"success"| SUCCESS
    INVOKE -->|"error"| ERROR
    SUCCESS --> REPLY
    ERROR --> REPLY
    REPLY --> OQ
