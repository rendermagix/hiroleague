graph TD
    START["ChannelManager.run()"]
    WS["Start local<br/>WebSocket server"]
    SPAWN["_spawn_channels()<br/>for each enabled channel"]
    KILL["Kill stale PID<br/>from previous run"]
    PROC["subprocess.Popen()<br/>channel command + --hiro-ws"]
    PID["Write PID to disk"]
    WAIT["Wait for stop_event"]
    STOP["Send channel.stop<br/>to all plugins"]
    SLEEP["Wait 1 second"]
    TERM["Terminate remaining<br/>subprocesses"]
    CLEAN["Remove PID files"]

    START --> WS
    WS --> SPAWN
    SPAWN --> KILL
    KILL --> PROC
    PROC --> PID
    PID --> WAIT
    WAIT --> STOP
    STOP --> SLEEP
    SLEEP --> TERM
    TERM --> CLEAN
